generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ModeType {
  university
  competitive

  @@map("mode_type")
}

enum TaskType {
  task
  exam
  reminder

  @@map("task_type")
}

enum TaskStatus {
  todo
  in_progress
  done
  archived

  @@map("task_status")
}

model Profile {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auth_uid     String?         @unique
  full_name    String?
  email        String?         @unique
  avatar_url   String?
  current_mode ModeType?       @default(university)
  timezone     String?
  locale       String?         @default("pt-BR")
  metadata     Json?
  created_at   DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?       @default(now()) @db.Timestamptz(6)
  subjects     Subject[]
  tasks        Task[]
  sessions     StudySession[]
  events       CalendarEvent[]
  notifications Notification[]

  @@map("profiles")
}

model Mode {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String    @unique
  name        String
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@map("modes")
}

model Subject {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  mode       ModeType? @default(university)
  name       String
  professor  String?
  room       String?
  color      String?
  code       String?
  is_active  Boolean?  @default(true)
  metadata   Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  user       Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks      Task[]
  sessions   StudySession[]

  @@index([user_id], map: "subjects_user_idx")
  @@index([mode], map: "subjects_mode_idx")
  @@map("subjects")
}

model Task {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String         @db.Uuid
  subject_id        String?        @db.Uuid
  title             String
  description       String?
  type              TaskType?      @default(task)
  status            TaskStatus?    @default(todo)
  priority          Int?           @default(0) @db.SmallInt
  due_date          DateTime?      @db.Timestamptz(6)
  estimated_minutes Int?
  completed_at      DateTime?      @db.Timestamptz(6)
  recurrence        Json?
  tags              String[]
  metadata          Json?
  created_at        DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?      @default(now()) @db.Timestamptz(6)
  user              Profile        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subject           Subject?       @relation(fields: [subject_id], references: [id], onDelete: SetNull)
  events            CalendarEvent[]

  @@index([user_id], map: "tasks_user_idx")
  @@index([subject_id], map: "tasks_subject_idx")
  @@index([user_id, status], map: "tasks_user_status_idx")
  @@map("tasks")
}

model StudySession {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String         @db.Uuid
  subject_id        String?        @db.Uuid
  started_at        DateTime       @db.Timestamptz(6)
  ended_at          DateTime       @db.Timestamptz(6)
  duration_minutes  Int?
  questions_answered Int?          @default(0)
  depth             Int?           @db.SmallInt
  notes             String?
  metadata          Json?
  created_at        DateTime?      @default(now()) @db.Timestamptz(6)
  user              Profile        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  subject           Subject?       @relation(fields: [subject_id], references: [id], onDelete: SetNull)
  events            CalendarEvent[]

  @@index([user_id], map: "study_sessions_user_idx")
  @@index([subject_id], map: "study_sessions_subject_idx")
  @@index([user_id, started_at(sort: Desc)], map: "study_sessions_user_started_idx")
  @@map("study_sessions")
}

model CalendarEvent {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String       @db.Uuid
  task_id     String?      @db.Uuid
  session_id  String?      @db.Uuid
  title       String
  description String?
  start_at    DateTime     @db.Timestamptz(6)
  end_at      DateTime     @db.Timestamptz(6)
  is_all_day  Boolean?     @default(false)
  recurrence  Json?
  metadata    Json?
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at  DateTime?    @default(now()) @db.Timestamptz(6)
  user        Profile      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task        Task?        @relation(fields: [task_id], references: [id], onDelete: SetNull)
  session     StudySession? @relation(fields: [session_id], references: [id], onDelete: SetNull)

  @@index([user_id], map: "calendar_events_user_idx")
  @@index([start_at], map: "calendar_events_start_idx")
  @@map("calendar_events")
}

model Notification {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  type         String
  payload      Json?
  read         Boolean?  @default(false)
  delivered_at DateTime? @db.Timestamptz(6)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  user         Profile   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read], map: "notifications_user_read_idx")
  @@map("notifications")
}
